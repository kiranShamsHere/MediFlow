rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stocks/{doc} { 
      allow read, write: if request.auth != null && request.auth.uid == resource.data.facilityId; 
    }
    match /requests/{doc} { 
      allow read: if true; 
      allow write: if request.auth != null; 
    }  // Admin reads all
    // Additional basic rules to ensure everything works
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
